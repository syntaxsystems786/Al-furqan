generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  topNotes    String?
  middleNotes String?
  baseNotes   String?
  price       Float
  categoryId  Int?
  category    Category?          @relation(fields: [categoryId], references: [id])
  variations  ProductVariation[]
  images      ProductImage[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  url       String
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ProductVariation {
  id        Int         @id @default(autoincrement())
  size      String      // e.g., S, M, L, XL
  color     String      // e.g., Red, Blue
  stock     Int         @default(0)
  productId Int
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Order {
  id            Int         @id @default(autoincrement())
  customerName  String
  email         String
  phone         String
  address       String
  city          String
  totalAmount   Float
  paymentMethod String      // JazzCash, EasyPaisa, Card, Bank
  status        String      @default("PENDING") // PENDING, PROCESSING, SHIPPED, DELIVERED, CANCELLED
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id                 Int              @id @default(autoincrement())
  orderId            Int
  order              Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariationId Int?
  variation          ProductVariation? @relation(fields: [productVariationId], references: [id], onDelete: SetNull)
  productName        String?
  productSize        String?
  productColor       String?
  quantity           Int
  priceAtPurchase    Float
}

model SiteSettings {
  id               Int      @id @default(autoincrement())
  heroImageUrl     String?
  featuredProducts Json?
  journalEntries   Json?
  updatedAt        DateTime @updatedAt
}
